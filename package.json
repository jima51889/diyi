{
  "name": "chongqing-city-quest",
  "version": "0.1.0",
  "private": true,
  "description": "重庆城市探秘 V1.0 Monorepo",
  "scripts": {
    "dev:api": "pnpm --filter @cq-quest/api start:dev",
    "dev:miniapp": "pnpm --filter @cq-quest/miniapp dev:weapp",
    "dev:h5": "pnpm --filter @cq-quest/h5 dev",
    "dev:admin": "pnpm --filter @cq-quest/admin dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "prisma:generate": "pnpm --filter @cq-quest/api prisma:generate",
    "prisma:migrate": "pnpm --filter @cq-quest/api prisma:migrate"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0"
  }
}
